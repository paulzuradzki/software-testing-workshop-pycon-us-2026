{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "pytest: current test file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "args": ["-v", "${file}"],
      "justMyCode": false
    },
    {
      "name": "pytest: current test function (cursor)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "args": ["-v", "${file}::${selectedText}"],
      "justMyCode": false
    },
    {
      "name": "pytest: by -k pattern (prompts)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "args": [
        "-v",
        "${file}",
        "-k",
        "${input:keywordExpr}"
      ],
      "justMyCode": false
    },
    {
      "name": "pytest: by mark (prompts)",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "args": [
        "-v",
        "${file}",
        "-m",
        "${input:markExpr}"
      ],
      "justMyCode": false
    },
    {
      "name": "pytest: whole solutions/ suite",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "console": "integratedTerminal",
      "args": ["-v", "solutions/"],
      "justMyCode": false
    },
    {
      "name": "Python: current file (no test runner)",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    }
  ],
  "inputs": [
    {
      "id": "keywordExpr",
      "type": "promptString",
      "description": "pytest -k expression (e.g. 'celsius and not freezing')"
    },
    {
      "id": "markExpr",
      "type": "promptString",
      "description": "pytest -m expression (e.g. 'slow' or 'not slow')"
    }
  ]
}
